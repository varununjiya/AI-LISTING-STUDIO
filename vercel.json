{
  "version": 2,
  "builds": [
    {
      "src": "AI-LISTING-STUDIO-main/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "AI-LISTING-STUDIO-main/backend/server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/AI-LISTING-STUDIO-main/backend/server.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/AI-LISTING-STUDIO-main/frontend/build/index.html"
    }
  ]
}
